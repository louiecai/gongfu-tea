 1: export async function requestNotificationPermission(): Promise<boolean> {
 2:   if (typeof window === "undefined" || !("Notification" in window)) {
 3:     return false;
 4:   }
 5:   if (Notification.permission === "granted") return true;
 6:   if (Notification.permission === "denied") return false;
 7:   const result = await Notification.requestPermission();
 8:   return result === "granted";
 9: }
10: 
11: export function notifySteepDone(title: string, body: string): void {
12:   if (typeof window === "undefined" || !("Notification" in window)) return;
13:   if (Notification.permission !== "granted") return;
14:   const options = { body, icon: "/icon-192.png", tag: "gongfu-steep" };
15:   try {
16:     new Notification(title, options);
17:   } catch {
18:     // Some platforms (Android) only allow notifications via the SW registration.
19:     void navigator.serviceWorker?.ready.then((reg) =>
20:       reg.showNotification(title, options),
21:     );
22:   }
23: }
24: 
25: export function vibrate(): void {
26:   if (typeof navigator !== "undefined" && "vibrate" in navigator) {
27:     navigator.vibrate([200, 100, 200]);
28:   }
29: }
