<file path="src/store/session.ts">
  1: import { create } from "zustand";
  2: import type { SteepRecord, TeaProfile } from "@/lib/types";
  3: import {
  4:   finishTimer,
  5:   idleTimer,
  6:   nudgeTimer,
  7:   pauseTimer,
  8:   scaledSteepMs,
  9:   startTimer,
 10:   type TimerState,
 11: } from "@/lib/timer";
 12: import { leafGrams } from "@/lib/brew";
 13: import { unlockAudio } from "@/lib/audio";
 14: import { useActiveSessions } from "./activeSessions";
 15: import { useLog } from "./log";
 16: import { useStash } from "./stash";
 17: import { useSettings } from "./settings";
 18: 
 19: interface SessionStore {
 20:   tea: TeaProfile | null;
 21:   /** Per-steep durations in ms, strength already applied. */
 22:   steepDurations: number[];
 23:   steepIndex: number;
 24:   timer: TimerState;
 25:   steepsCompleted: number;
 26:   finished: boolean;
 27:   logId: string | null;
 28:   /** 1-based number of the steep that just chimed; consumed by the alarm UI. */
 29:   justFinishedSteep: number | null;
 30:   /** Cumulative ms actually spent steeping this session (nudges included). */
 31:   totalBrewMs: number;
 32:   /** When each pour started and how long it actually ran. */
 33:   steeps: SteepRecord[];
 34: 
 35:   begin: (tea: TeaProfile, strength: number) => void;
 36:   startSteep: (gramsOverride?: number) => void;
 37:   pause: () => void;
 38:   resume: () => void;
 39:   nudge: (deltaSec: number) => void;
 40:   /** Steep timer hit zero: record it and advance (or wait, per profile). */
 41:   completeSteep: () => void;
 42:   /** Move to the next steep without brewing the current one. */
 43:   skipSteep: () => void;
 44:   /** Manual advance used when autoAdvance is off. */
 45:   nextSteep: () => void;
 46:   clearAlarm: () => void;
 47:   end: () => void;
 48: }
 49: 
 50: const EMPTY = {
 51:   tea: null,
 52:   steepDurations: [] as number[],
 53:   steepIndex: 0,
 54:   timer: idleTimer(0),
 55:   steepsCompleted: 0,
 56:   finished: false,
 57:   logId: null,
 58:   justFinishedSteep: null,
 59:   totalBrewMs: 0,
 60:   steeps: [] as SteepRecord[],
 61: };
 62: 
 63: export const useSession = create<SessionStore>((set, get) => ({
 64:   ...EMPTY,
 65: 
 66:   begin: (tea, strength) => {
 67:     // Switching away from a different, unfinished tea loses nothing — the
 68:     // subscriber below keeps useActiveSessions current on every change.
 69:     //
 70:     // Resume this tea's own session if one's still unfinished, rather than
 71:     // starting over.
 72:     const existing = useActiveSessions
 73:       .getState()
 74:       .sessions.find((s) => s.teaId === tea.id);
 75:     if (existing) {
 76:       set({
 77:         tea,
 78:         steepDurations: existing.steepDurations,
 79:         steepIndex: existing.steepIndex,
 80:         timer: existing.timer,
 81:         steepsCompleted: existing.steepsCompleted,
 82:         finished: false,
 83:         logId: existing.logId,
 84:         justFinishedSteep: existing.justFinishedSteep,
 85:         totalBrewMs: existing.totalBrewMs,
 86:         steeps: existing.steeps,
 87:       });
 88:       return;
 89:     }
 90: 
 91:     const steepDurations = tea.steepsSec.map((s) => scaledSteepMs(s, strength));
 92:     const logId = `brew-${Date.now().toString(36)}`;
 93:     useLog.getState().add({
 94:       id: logId,
 95:       teaId: tea.id,
 96:       teaName: tea.name,
 97:       liquorColor: tea.liquorColor,
 98:       startedAt: Date.now(),
 99:       steepsCompleted: 0,
100:       totalSteeps: tea.steepsSec.length,
101:       tempC: tea.tempC,
102:       totalBrewMs: 0,
103:     });
104:     set({
105:       ...EMPTY,
106:       tea,
107:       steepDurations,
108:       timer: idleTimer(steepDurations[0]),
109:       logId,
110:     });
111:   },
112: 
113:   startSteep: (gramsOverride) => {
114:     unlockAudio();
115:     const { steepIndex, tea, logId, steeps } = get();
116:     // First steep only: capture the leaf grams (from the page's grams
117:     // stepper, or derived from ratio+vessel if not given), then deplete the
118:     // stash once for the whole session.
119:     if (steepIndex === 0 && tea) {
120:       const vesselMl = useSettings.getState().vesselMl;
121:       const grams =
122:         gramsOverride ?? leafGrams(tea.ratioGramsPer100ml, vesselMl);
123:       useStash.getState().consumeForSession(tea.id, grams);
124:       if (logId) useLog.getState().update(logId, { gramsUsed: grams });
125:     }
126:     set({
127:       timer: startTimer(get().timer),
128:       justFinishedSteep: null,
129:       steeps: [...steeps, { steepIndex, startedAt: Date.now(), durationMs: 0 }],
130:     });
131:   },
132: 
133:   pause: () => set({ timer: pauseTimer(get().timer) }),
134:   resume: () => set({ timer: startTimer(get().timer) }),
135:   nudge: (deltaSec) => set({ timer: nudgeTimer(get().timer, deltaSec * 1000) }),
136: 
137:   completeSteep: () => {
138:     const {
139:       tea,
140:       steepIndex,
141:       steepDurations,
142:       steepsCompleted,
143:       logId,
144:       timer,
145:       steeps,
146:     } = get();
147:     if (!tea) return;
148:     const completed = steepsCompleted + 1;
149:     const totalBrewMs = get().totalBrewMs + timer.durationMs;
150:     const updatedSteeps = steeps.map((s, i) =>
151:       i === steeps.length - 1 ? { ...s, durationMs: timer.durationMs } : s,
152:     );
153:     if (logId) {
154:       useLog.getState().update(logId, {
155:         steepsCompleted: completed,
156:         totalBrewMs,
157:         steeps: updatedSteeps,
158:       });
159:     }
160:     set({ totalBrewMs, steeps: updatedSteeps });
161:     const isLast = steepIndex >= steepDurations.length - 1;
162:     if (isLast) {
163:       set({
164:         steepsCompleted: completed,
165:         finished: true,
166:         timer: finishTimer(get().timer),
167:         justFinishedSteep: steepIndex + 1,
168:       });
169:     } else if (tea.autoAdvance) {
170:       set({
171:         steepsCompleted: completed,
172:         steepIndex: steepIndex + 1,
173:         timer: idleTimer(steepDurations[steepIndex + 1]),
174:         justFinishedSteep: steepIndex + 1,
175:       });
176:     } else {
177:       set({
178:         steepsCompleted: completed,
179:         timer: finishTimer(get().timer),
180:         justFinishedSteep: steepIndex + 1,
181:       });
182:     }
183:   },
184: 
185:   skipSteep: () => {
186:     const { steepIndex, steepDurations } = get();
187:     if (steepIndex >= steepDurations.length - 1) {
188:       set({ finished: true, timer: finishTimer(get().timer) });
189:     } else {
190:       set({
191:         steepIndex: steepIndex + 1,
192:         timer: idleTimer(steepDurations[steepIndex + 1]),
193:         justFinishedSteep: null,
194:       });
195:     }
196:   },
197: 
198:   nextSteep: () => {
199:     const { steepIndex, steepDurations } = get();
200:     if (steepIndex >= steepDurations.length - 1) {
201:       set({ finished: true });
202:     } else {
203:       set({
204:         steepIndex: steepIndex + 1,
205:         timer: idleTimer(steepDurations[steepIndex + 1]),
206:         justFinishedSteep: null,
207:       });
208:     }
209:   },
210: 
211:   clearAlarm: () => set({ justFinishedSteep: null }),
212:   end: () => {
213:     const { logId } = get();
214:     if (logId) useActiveSessions.getState().remove(logId);
