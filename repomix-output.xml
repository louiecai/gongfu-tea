<file path="public/sw.js">
 1: /*
 2:  * App-shell service worker. Network-first for navigations (so deploys show
 3:  * up), cache-first for hashed static assets, and an offline fallback of the
 4:  * last good shell. All data lives in localStorage, so offline the app is
 5:  * fully functional once the shell is cached.
 6:  */
 7: const CACHE = "gongfu-v1";
 8: const SHELL = ["/", "/manifest.json", "/icon-192.png", "/icon-512.png"];
 9: 
10: self.addEventListener("install", (event) => {
11:   event.waitUntil(
12:     caches
13:       .open(CACHE)
14:       .then((cache) => cache.addAll(SHELL))
15:       .then(() => self.skipWaiting()),
16:   );
17: });
18: 
19: self.addEventListener("activate", (event) => {
20:   event.waitUntil(
21:     caches
22:       .keys()
23:       .then((keys) =>
24:         Promise.all(keys.filter((k) => k !== CACHE).map((k) => caches.delete(k))),
25:       )
26:       .then(() => self.clients.claim()),
27:   );
28: });
29: 
30: self.addEventListener("fetch", (event) => {
31:   const { request } = event;
32:   if (request.method !== "GET") return;
33:   const url = new URL(request.url);
34:   if (url.origin !== self.location.origin) return;
35: 
36:   if (request.mode === "navigate") {
37:     event.respondWith(
38:       fetch(request)
39:         .then((response) => {
40:           const copy = response.clone();
41:           caches.open(CACHE).then((cache) => cache.put("/", copy));
42:           return response;
43:         })
44:         .catch(() => caches.match("/")),
45:     );
46:     return;
47:   }
48: 
49:   event.respondWith(
50:     caches.match(request).then(
51:       (cached) =>
52:         cached ||
53:         fetch(request).then((response) => {
54:           if (response.ok && url.pathname.startsWith("/_next/static/")) {
55:             const copy = response.clone();
56:             caches.open(CACHE).then((cache) => cache.put(request, copy));
57:           }
58:           return response;
59:         }),
60:     ),
61:   );
62: });
</file>

