 3: /**
 4:  * A row of tiny tasting cups: filled = poured, ringed = current, faint =
 5:  * still to come.
 6:  */
 7: export function SteepDots({
 8:   total,
 9:   current,
10:   completed,
11:   color,
12: }: {
13:   total: number;
14:   /** 0-based index of the steep on screen. */
15:   current: number;
16:   completed: number;
17:   color: string;
18: }) {
19:   return (
20:     <ol
21:       aria-label={`Steep ${current + 1} of ${total}, ${completed} poured`}
22:       className="flex flex-wrap items-center justify-center gap-2"
23:     >
24:       {Array.from({ length: total }, (_, i) => {
25:         const poured = i < completed;
26:         const isCurrent = i === current;
27:         return (
28:           <li
29:             key={i}
30:             className={`rounded-full transition-all duration-300 ${
31:               isCurrent ? "h-3.5 w-3.5" : "h-2.5 w-2.5"
32:             }`}
33:             style={{
34:               background: poured ? color : "transparent",
35:               boxShadow: isCurrent
36:                 ? `inset 0 0 0 2px ${color}`
37:                 : poured
38:                   ? "none"
39:                   : "inset 0 0 0 1.5px var(--line)",
40:             }}
41:           />
42:         );
43:       })}
44:     </ol>
