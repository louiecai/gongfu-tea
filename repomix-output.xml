219: // Keep useActiveSessions in sync with whichever session is currently open,
220: // so a reload or closed tab can resume it — and any other unfinished
221: // session — later. A finished session has nothing left to resume, so it
222: // drops out of the list instead.
223: if (typeof window !== "undefined") {
224:   useSession.subscribe((state) => {
225:     if (!state.tea || !state.logId) return;
226:     if (state.finished) {
227:       useActiveSessions.getState().remove(state.logId);
228:       return;
229:     }
230:     useActiveSessions.getState().upsert({
231:       logId: state.logId,
232:       teaId: state.tea.id,
233:       steepIndex: state.steepIndex,
234:       steepDurations: state.steepDurations,
235:       steepsCompleted: state.steepsCompleted,
236:       totalBrewMs: state.totalBrewMs,
237:       timer: state.timer,
238:       justFinishedSteep: state.justFinishedSteep,
239:       steeps: state.steeps,
240:     });
241:   });
242: }
