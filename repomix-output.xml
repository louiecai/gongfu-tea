<file path="src/lib/audio.ts">
 1: /**
 2:  * Synthesized meditation-bell chime via Web Audio — no asset file needed.
 3:  * The AudioContext is created/resumed inside a user gesture (the Start
 4:  * button), which satisfies autoplay policies.
 5:  */
 6: 
 7: let ctx: AudioContext | null = null;
 8: 
 9: export function unlockAudio(): void {
10:   if (typeof window === "undefined") return;
11:   if (!ctx) {
12:     const AC =
13:       window.AudioContext ??
14:       (window as unknown as { webkitAudioContext?: typeof AudioContext })
15:         .webkitAudioContext;
16:     if (!AC) return;
17:     ctx = new AC();
18:   }
19:   if (ctx.state === "suspended") void ctx.resume();
20: }
21: 
22: export function playChime(): void {
23:   if (!ctx || ctx.state !== "running") return;
24:   const now = ctx.currentTime;
25:   const master = ctx.createGain();
26:   master.gain.setValueAtTime(0.5, now);
27:   master.connect(ctx.destination);
28: 
29:   // A bell is a fundamental plus slightly inharmonic partials that decay
30:   // at different rates.
31:   const partials: Array<[freq: number, gain: number, decay: number]> = [
32:     [523.25, 0.6, 2.8], // C5 fundamental
33:     [1046.5, 0.25, 2.0],
34:     [1567.98, 0.12, 1.4],
35:     [2093.0, 0.06, 1.0],
36:   ];
37: 
38:   for (const [freq, gain, decay] of partials) {
39:     const osc = ctx.createOscillator();
40:     const g = ctx.createGain();
41:     osc.type = "sine";
42:     osc.frequency.setValueAtTime(freq, now);
43:     g.gain.setValueAtTime(0, now);
44:     g.gain.linearRampToValueAtTime(gain, now + 0.01);
45:     g.gain.exponentialRampToValueAtTime(0.0001, now + decay);
46:     osc.connect(g);
47:     g.connect(master);
48:     osc.start(now);
49:     osc.stop(now + decay + 0.1);
50:   }
51: }
</file>

