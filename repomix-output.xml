<file path="src/lib/timer.ts">
 1: export type TimerStatus = "idle" | "running" | "paused" | "done";
 2: 
 3: export interface TimerState {
 4:   status: TimerStatus;
 5:   /** Epoch ms when the running steep ends. Only meaningful while running. */
 6:   endsAt: number | null;
 7:   /** Ms left while idle/paused; snapshot taken on pause. */
 8:   remainingMs: number;
 9:   /** Full duration of the current steep in ms (after strength/nudges). */
10:   durationMs: number;
11: }
12: 
13: export function idleTimer(durationMs: number): TimerState {
14:   return { status: "idle", endsAt: null, remainingMs: durationMs, durationMs };
15: }
16: 
17: export function startTimer(t: TimerState, now = Date.now()): TimerState {
18:   if (t.status === "running" || t.status === "done") return t;
19:   return { ...t, status: "running", endsAt: now + t.remainingMs };
20: }
21: 
22: export function pauseTimer(t: TimerState, now = Date.now()): TimerState {
23:   if (t.status !== "running" || t.endsAt === null) return t;
24:   return {
25:     ...t,
26:     status: "paused",
27:     endsAt: null,
28:     remainingMs: Math.max(0, t.endsAt - now),
29:   };
30: }
31: 
32: /** Ms remaining right now, whatever the status. */
33: export function remainingMs(t: TimerState, now = Date.now()): number {
34:   if (t.status === "running" && t.endsAt !== null) {
35:     return Math.max(0, t.endsAt - now);
36:   }
37:   if (t.status === "done") return 0;
38:   return t.remainingMs;
39: }
40: 
41: export function isExpired(t: TimerState, now = Date.now()): boolean {
42:   return t.status === "running" && t.endsAt !== null && now >= t.endsAt;
43: }
44: 
45: /** ±deltaMs on the current steep. Works running or paused; clamps at 1s. */
46: export function nudgeTimer(
47:   t: TimerState,
48:   deltaMs: number,
49:   now = Date.now(),
50: ): TimerState {
51:   const MIN = 1000;
52:   if (t.status === "running" && t.endsAt !== null) {
53:     const left = Math.max(MIN, t.endsAt - now + deltaMs);
54:     return {
55:       ...t,
56:       endsAt: now + left,
57:       durationMs: Math.max(MIN, t.durationMs + deltaMs),
58:     };
59:   }
60:   if (t.status === "idle" || t.status === "paused") {
61:     const left = Math.max(MIN, t.remainingMs + deltaMs);
62:     return {
63:       ...t,
64:       remainingMs: left,
65:       durationMs: Math.max(MIN, t.durationMs + deltaMs),
66:     };
67:   }
68:   return t;
69: }
70: 
71: export function finishTimer(t: TimerState): TimerState {
72:   return { ...t, status: "done", endsAt: null, remainingMs: 0 };
73: }
74: 
75: /** Apply the global strength multiplier to a steep's base seconds. */
76: export function scaledSteepMs(baseSec: number, strength: number): number {
77:   return Math.max(1000, Math.round(baseSec * strength) * 1000);
78: }
79: 
80: /** "1:05" / "0:42" style display. */
81: export function formatSeconds(totalSec: number): string {
82:   const s = Math.max(0, Math.ceil(totalSec));
83:   const m = Math.floor(s / 60);
84:   const r = s % 60;
85:   return `${m}:${r.toString().padStart(2, "0")}`;
86: }
87: 
88: export function formatMs(ms: number): string {
89:   return formatSeconds(ms / 1000);
90: }
</file>

