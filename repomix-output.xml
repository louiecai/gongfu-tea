<file path="src/lib/share.ts">
 1: import type { TeaCategory, TeaIconKey, TeaProfile } from "./types";
 2: import { CATEGORY_LABELS } from "./types";
 3: 
 4: /**
 5:  * Encode/decode a custom profile into a URL-safe string so profiles can be
 6:  * shared as links with no backend.
 7:  */
 8: 
 9: function toBase64Url(s: string): string {
10:   const b64 =
11:     typeof window !== "undefined"
12:       ? window.btoa(unescape(encodeURIComponent(s)))
13:       : Buffer.from(s, "utf8").toString("base64");
14:   return b64.replace(/\+/g, "-").replace(/\//g, "_").replace(/=+$/, "");
15: }
16: 
17: function fromBase64Url(s: string): string {
18:   const b64 = s.replace(/-/g, "+").replace(/_/g, "/");
19:   return typeof window !== "undefined"
20:     ? decodeURIComponent(escape(window.atob(b64)))
21:     : Buffer.from(b64, "base64").toString("utf8");
22: }
23: 
24: export function encodeProfile(p: TeaProfile): string {
25:   const compact = {
26:     n: p.name,
27:     cn: p.chineseName,
28:     c: p.category,
29:     lc: p.liquorColor,
30:     i: p.icon,
31:     t: p.tempC,
32:     r: p.ratioGramsPer100ml,
33:     s: p.steepsSec,
34:     a: p.autoAdvance ? 1 : 0,
35:     d: p.description,
36:   };
37:   return toBase64Url(JSON.stringify(compact));
38: }
39: 
40: const ICON_KEYS: TeaIconKey[] = [
41:   "leaf",
42:   "bud",
43:   "twist",
44:   "pearl",
45:   "strip",
46:   "cake",
47:   "brick",
48:   "flower",
49:   "needle",
50: ];
51: 
52: export function decodeProfile(encoded: string): TeaProfile | null {
53:   try {
54:     const raw = JSON.parse(fromBase64Url(encoded)) as Record<string, unknown>;
55:     const name = typeof raw.n === "string" ? raw.n.slice(0, 60) : null;
56:     const category =
57:       typeof raw.c === "string" && raw.c in CATEGORY_LABELS
58:         ? (raw.c as TeaCategory)
59:         : null;
60:     const steeps = Array.isArray(raw.s)
61:       ? raw.s
62:           .filter((x): x is number => typeof x === "number" && isFinite(x))
63:           .map((x) => Math.min(3600, Math.max(1, Math.round(x))))
64:       : null;
65:     if (!name || !category || !steeps || steeps.length === 0) return null;
66: 
67:     return {
68:       id: `custom-${Date.now().toString(36)}`,
69:       name,
70:       chineseName:
71:         typeof raw.cn === "string" ? raw.cn.slice(0, 30) : undefined,
72:       category,
73:       liquorColor:
74:         typeof raw.lc === "string" && /^#[0-9a-fA-F]{6}$/.test(raw.lc)
75:           ? raw.lc
76:           : "#c8a25e",
77:       icon: ICON_KEYS.includes(raw.i as TeaIconKey)
78:         ? (raw.i as TeaIconKey)
79:         : "leaf",
80:       tempC:
81:         typeof raw.t === "number" ? Math.min(100, Math.max(40, raw.t)) : 95,
82:       ratioGramsPer100ml:
83:         typeof raw.r === "number" ? Math.min(20, Math.max(0.5, raw.r)) : 5,
84:       steepsSec: steeps.slice(0, 20),
85:       autoAdvance: raw.a !== 0,
86:       description:
87:         typeof raw.d === "string" ? raw.d.slice(0, 200) : undefined,
88:       custom: true,
89:     };
90:   } catch {
91:     return null;
92:   }
93: }
</file>

