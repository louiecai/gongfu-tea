360:       </AnimatePresence>
361:     </div>
362:   );
363: }
364: 
365: function FinishedView({ color }: { color: string }) {
366:   const session = useSession();
367:   const router = useRouter();
368:   const { t } = useT();
369:   const [rating, setRating] = useState(0);
370:   const [note, setNote] = useState("");
371:   const [saved, setSaved] = useState(false);
372: 
373:   const save = () => {
374:     if (session.logId) {
375:       useLog.getState().update(session.logId, {
376:         rating: rating || undefined,
377:         note: note.trim() || undefined,
378:       });
379:     }
380:     setSaved(true);
381:   };
382: 
383:   return (
384:     <motion.div
385:       initial={{ opacity: 0, y: 12 }}
386:       animate={{ opacity: 1, y: 0 }}
387:       className="flex flex-1 flex-col items-center pt-8 text-center"
388:     >
389:       <span
390:         className="flex h-20 w-20 items-center justify-center rounded-full text-3xl"
391:         style={{ background: `color-mix(in srgb, ${color} 20%, transparent)` }}
392:       >
393:         🍵
394:       </span>
395:       <h2 className="font-display mt-5 text-2xl font-medium">
396:         {t.lastSteepTitle}
397:       </h2>
398:       <p className="mt-1 text-sm text-muted">
399:         {t.lastSteepBody(session.steepsCompleted, session.steepDurations.length)}
400:       </p>
401: 
402:       <div className="mt-5 flex gap-1.5" role="radiogroup" aria-label="Rating">
403:         {[1, 2, 3, 4, 5].map((n) => (
404:           <button
405:             key={n}
406:             role="radio"
407:             aria-checked={rating === n}
408:             onClick={() => setRating(n)}
409:             className={`text-2xl transition-transform hover:scale-110 ${
410:               n <= rating ? "" : "opacity-25 grayscale"
411:             }`}
412:           >
413:             ★
414:           </button>
415:         ))}
416:       </div>
417: 
418:       <textarea
419:         value={note}
420:         onChange={(e) => setNote(e.target.value)}
421:         placeholder={t.notePlaceholder}
422:         rows={3}
423:         className="mt-4 w-full max-w-sm rounded-2xl border border-line bg-surface p-3 text-sm placeholder:text-muted focus:border-muted focus:outline-none"
424:       />
425: 
426:       <div className="mt-5 flex items-center gap-3">
427:         <button
428:           onClick={save}
429:           disabled={saved}
430:           className="rounded-full px-6 py-3 text-sm font-bold text-white transition-transform active:scale-95 disabled:opacity-60"
431:           style={{ background: color }}
432:         >
433:           {saved ? t.saved : t.saveToLog}
434:         </button>
435:         <button
436:           onClick={() => {
437:             session.end();
438:             leaveSession(router);
439:           }}
440:           className="rounded-full border border-line bg-surface px-6 py-3 text-sm font-semibold text-muted hover:text-ink"
441:         >
442:           {t.done}
443:         </button>
444:       </div>
445:     </motion.div>
446:   );
447: }
448: 
449: export default function SessionPage() {
