237:             {t.strengthChip(
238:               settings.strength.toFixed(2).replace(/0+$/, "").replace(/\.$/, ""),
239:             )}
240:           </span>
241:         )}
242:       </div>
243: 
244:       <AnimatePresence mode="wait">
245:         {finished ? (
246:           <FinishedView key="done" color={color} />
247:         ) : (
248:           <motion.div
249:             key="brewing"
250:             initial={{ opacity: 0 }}
251:             animate={{ opacity: 1 }}
252:             exit={{ opacity: 0, scale: 0.97 }}
253:             className="flex flex-1 flex-col"
254:           >
255:             <p className="mb-3 text-center text-xs font-semibold uppercase tracking-[0.2em] text-muted">
