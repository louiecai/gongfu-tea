22:       className="fixed inset-x-0 bottom-0 z-40 border-t border-line bg-surface/90 backdrop-blur-sm md:inset-x-auto md:left-1/2 md:top-auto md:bottom-4 md:w-auto md:-translate-x-1/2 md:rounded-full md:border md:px-2 md:shadow-lg md:shadow-[var(--lift)]"
