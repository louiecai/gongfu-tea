 35:   -webkit-tap-highlight-color: transparent;
 36: }
 37: 
 38: body {
 39:   background: var(--bg);
 40:   color: var(--ink);
 41:   font-family: var(--font-nunito), system-ui, sans-serif;
 42:   -webkit-font-smoothing: antialiased;
 43:   min-height: 100dvh;
 44:   overflow-x: hidden;
 45: }
 46: 
 47: .font-display {
 48:   font-family: var(--font-fraunces), Georgia, serif;
 49: }
 50: 
 51: .tabular {
 52:   font-variant-numeric: tabular-nums;
 53:   font-feature-settings: "tnum";
 54: }
 55: 
 56: /* Gentle floating of the liquid wave inside the timer cup. */
 57: @keyframes wave-drift {
 58:   from {
 59:     transform: translateX(0);
 60:   }
 61:   to {
 62:     transform: translateX(-220px);
 63:   }
 64: }
 65: 
 66: .wave-drift {
 67:   animation: wave-drift 4.5s linear infinite;
 68: }
 69: 
 70: .wave-drift-slow {
 71:   animation: wave-drift 7s linear infinite reverse;
 72: }
 73: 
 74: /* Ripple pulse when a steep completes. */
 75: @keyframes steep-ripple {
 76:   0% {
 77:     transform: scale(1);
 78:     opacity: 0.55;
 79:   }
 80:   100% {
 81:     transform: scale(1.45);
 82:     opacity: 0;
 83:   }
 84: }
 85: 
 86: .steep-ripple {
 87:   animation: steep-ripple 1.6s ease-out infinite;
 88: }
 89: 
 90: /* Soft glow behind the cup while a steep just finished. */
 91: @keyframes steep-glow {
 92:   0%, 100% {
 93:     opacity: 0.35;
 94:     transform: scale(1);
 95:   }
 96:   50% {
 97:     opacity: 0.8;
 98:     transform: scale(1.08);
 99:   }
100: }
101: 
102: .steep-glow {
103:   animation: steep-glow 1.8s ease-in-out infinite;
104: }
105: 
106: /* Soft "come tap me" breathing on the countdown ring while idle. */
107: @keyframes ring-idle-pulse {
108:   0%, 100% {
109:     opacity: 0.55;
110:   }
111:   50% {
112:     opacity: 1;
113:   }
114: }
115: 
116: .ring-idle-pulse {
117:   animation: ring-idle-pulse 2.4s ease-in-out infinite;
118: }
119: 
120: @media (prefers-reduced-motion: reduce) {
121:   .wave-drift,
122:   .wave-drift-slow,
123:   .steep-ripple,
124:   .steep-glow,
125:   .ring-idle-pulse {
126:     animation: none;
127:   }
128: }
129: 
130: :focus-visible {
131:   outline: 2px solid var(--muted);
132:   outline-offset: 2px;
133:   border-radius: 4px;
134: }
135: 
136: /* Buttons don't get a pointer cursor by default — add the affordance back,
137:    plus a light tactile press for every clickable control. */
138: button:not(:disabled) {
139:   cursor: pointer;
140:   transition: transform 0.15s ease;
141: }
142: 
143: button:not(:disabled):active {
144:   transform: scale(0.96);
145: }
146: 
147: label:has(> input[type="checkbox"]),
148: label:has(> input[type="file"]) {
149:   cursor: pointer;
150: }
151: 
152: /* Most navigation happens by tapping a card/link, not a button — give those
153:    the same tactile press so the app doesn't feel inert on a touch screen. */
