  6: import { CATEGORY_LABELS, type TeaCategory, type TeaProfile } from "@/lib/types";
  7: import { useProfiles, findTea } from "@/store/profiles";
  8: import { useSettings } from "@/store/settings";
  9: import { useLog } from "@/store/log";
 10: import { useActiveSessions } from "@/store/activeSessions";
 11: import { TeaCard } from "@/components/TeaCard";
 12: import { categoryLabel, teaNames } from "@/lib/i18n";
 13: import { useT } from "@/store/useT";
 14: 
 15: const CATEGORY_ORDER: TeaCategory[] = [
 16:   "green",
 17:   "yellow",
 18:   "white",
 19:   "oolong-light",
 20:   "oolong-dark",
 21:   "black",
 22:   "puer-sheng",
 23:   "puer-shou",
 24:   "heicha",
 25:   "herbal",
 26: ];
 27: 
 28: export default function HomePage() {
 29:   const custom = useProfiles((s) => s.custom);
 30:   const favoriteIds = useSettings((s) => s.favorites);
 31:   const sessions = useLog((s) => s.sessions);
 32:   const activeSessions = useActiveSessions((s) => s.sessions);
 33:   const { t, lang } = useT();
 34:   const [query, setQuery] = useState("");
 35: 
 36:   const brewingNow = useMemo(
 37:     () =>
 38:       activeSessions
 39:         .map((a) => ({ session: a, tea: findTea(a.teaId, custom) }))
 40:         .filter(
 41:           (x): x is { session: (typeof activeSessions)[number]; tea: TeaProfile } =>
 42:             !!x.tea,
 43:         ),
 44:     [activeSessions, custom],
 45:   );
 46: 
 47:   const favoriteTeas = useMemo(
 48:     () =>
 49:       favoriteIds
 50:         .map((id) => findTea(id, custom))
 51:         .filter((tea): tea is TeaProfile => !!tea),
 52:     [favoriteIds, custom],
 53:   );
 54: 
 55:   const recentTeas = useMemo(() => {
 56:     const seen = new Set<string>();
 57:     const result: TeaProfile[] = [];
 58:     for (const s of sessions) {
 59:       if (seen.has(s.teaId) || favoriteIds.includes(s.teaId)) continue;
 60:       seen.add(s.teaId);
 61:       const tea = findTea(s.teaId, custom);
 62:       if (tea) result.push(tea);
 63:       if (result.length >= 6) break;
 64:     }
 65:     return result;
 66:   }, [sessions, custom, favoriteIds]);
 67: 
 68:   const groups = useMemo(() => {
 69:     const q = query.trim().toLowerCase();
 70:     const matches = (tea: TeaProfile) =>
 71:       !q ||
 72:       tea.name.toLowerCase().includes(q) ||
 73:       (tea.chineseName ?? "").includes(q) ||
 74:       CATEGORY_LABELS[tea.category].toLowerCase().includes(q) ||
 75:       categoryLabel(tea.category, lang).includes(q);
 76: 
 77:     const byCategory = CATEGORY_ORDER.map((cat) => ({
 78:       cat,
 79:       teas: PRESET_TEAS.filter((t) => t.category === cat && matches(t)),
 80:     })).filter((g) => g.teas.length > 0);
 81: 
 82:     return { byCategory, customTeas: custom.filter(matches) };
 83:   }, [query, custom, lang]);
 84: 
 85:   return (
 86:     <div>
 87:       <header className="mb-6">
 88:         <p className="text-xs font-semibold uppercase tracking-[0.2em] text-muted">
 89:           {t.homeEyebrow}
 90:         </p>
 91:         <h1 className="font-display mt-1 text-3xl font-medium">
 92:           {t.homeTitle}
 93:         </h1>
 94:       </header>
 95: 
 96:       <div className="mb-6 flex gap-2">
 97:         <input
 98:           type="search"
 99:           value={query}
100:           onChange={(e) => setQuery(e.target.value)}
101:           placeholder={t.searchPlaceholder}
102:           aria-label={t.searchPlaceholder}
103:           className="w-full rounded-full border border-line bg-surface px-4 py-2.5 text-sm placeholder:text-muted focus:border-muted focus:outline-none"
104:         />
105:         <Link
106:           href="/profiles/new"
107:           className="flex shrink-0 items-center gap-1.5 rounded-full border border-line bg-surface px-4 py-2.5 text-sm font-semibold text-ink transition-colors hover:border-muted"
108:         >
109:           <span aria-hidden className="text-base leading-none">＋</span>
110:           {t.newTea}
111:         </Link>
112:       </div>
113: 
114:       {!query.trim() && brewingNow.length > 0 && (
115:         <section className="mb-7">
116:           <h2 className="mb-2.5 text-xs font-semibold uppercase tracking-[0.15em] text-muted">
117:             {t.continueBrewing}
118:           </h2>
119:           <ul className="space-y-2.5">
120:             {brewingNow.map(({ session, tea }) => (
121:               <li key={session.logId}>
122:                 <Link
123:                   href={`/session?tea=${tea.id}`}
124:                   className="flex items-center gap-3.5 rounded-2xl border border-line bg-surface p-3.5 transition-all hover:-translate-y-0.5 hover:shadow-md hover:shadow-[var(--lift)] active:scale-[.98]"
125:                   style={{ borderColor: tea.liquorColor }}
126:                 >
127:                   <span
128:                     aria-hidden
129:                     className="steep-glow h-3 w-3 shrink-0 rounded-full"
130:                     style={{ background: tea.liquorColor }}
131:                   />
132:                   <span className="min-w-0 flex-1">
133:                     <span className="font-display block truncate text-[15px] font-medium">
134:                       {teaNames(tea, lang).primary} ·{" "}
135:                       {t.steepOf(
136:                         session.steepIndex + 1,
137:                         session.steepDurations.length,
138:                       )}
139:                     </span>
140:                   </span>
141:                 </Link>
142:               </li>
143:             ))}
144:           </ul>
145:         </section>
146:       )}
147: 
148:       {!query.trim() && favoriteTeas.length > 0 && (
149:         <section className="mb-7">
150:           <h2 className="mb-2.5 text-xs font-semibold uppercase tracking-[0.15em] text-muted">
151:             {t.favoritesTitle}
152:           </h2>
153:           <ul className="grid gap-2.5 sm:grid-cols-2">
154:             {favoriteTeas.map((tea, i) => (
155:               <TeaCard key={tea.id} tea={tea} index={i} />
156:             ))}
157:           </ul>
158:         </section>
159:       )}
160: 
161:       {!query.trim() && recentTeas.length > 0 && (
162:         <section className="mb-7">
163:           <h2 className="mb-2.5 text-xs font-semibold uppercase tracking-[0.15em] text-muted">
164:             {t.recentlyBrewed}
165:           </h2>
166:           <ul className="grid gap-2.5 sm:grid-cols-2">
167:             {recentTeas.map((tea, i) => (
168:               <TeaCard key={tea.id} tea={tea} index={i} />
169:             ))}
170:           </ul>
171:         </section>
172:       )}
173: 
174:       {groups.customTeas.length > 0 && (
175:         <section className="mb-7">
176:           <div className="mb-2.5 flex items-baseline justify-between">
177:             <h2 className="text-xs font-semibold uppercase tracking-[0.15em] text-muted">
178:               {t.yourTeas}
179:             </h2>
180:             <Link
181:               href="/profiles"
182:               className="text-xs font-semibold text-muted hover:text-ink"
183:             >
184:               {t.manage}
185:             </Link>
186:           </div>
187:           <ul className="grid gap-2.5 sm:grid-cols-2">
188:             {groups.customTeas.map((tea, i) => (
189:               <TeaCard key={tea.id} tea={tea} index={i} />
190:             ))}
191:           </ul>
192:         </section>
193:       )}
194: 
195:       {groups.byCategory.map(({ cat, teas }) => (
196:         <section key={cat} className="mb-7">
197:           <h2 className="mb-2.5 text-xs font-semibold uppercase tracking-[0.15em] text-muted">
