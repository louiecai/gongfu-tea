  1: "use client";
  2: 
  3: import { Suspense, useCallback, useEffect, useRef, useState } from "react";
  4: import Link from "next/link";
  5: import { useRouter, useSearchParams } from "next/navigation";
  6: import { AnimatePresence, motion } from "framer-motion";
  7: import { findTea, useProfiles } from "@/store/profiles";
  8: import { useSession } from "@/store/session";
  9: import { useSettings } from "@/store/settings";
 10: import { useLog } from "@/store/log";
 11: import { formatMs, isExpired, remainingMs } from "@/lib/timer";
 12: import { leafGrams } from "@/lib/brew";
 13: import { playChime } from "@/lib/audio";
 14: import { notifySteepDone, vibrate } from "@/lib/alerts";
 15: import { TimerCup } from "@/components/TimerCup";
 16: import { SteepDots } from "@/components/SteepDots";
 17: import { STRINGS, teaNames } from "@/lib/i18n";
 18: import { useT } from "@/store/useT";
 19: 
 20: // Prefer a real back-navigation so the browser/Next restores wherever the
 21: // user scrolled to (a fresh push always lands at the top). Only push a new
 22: // entry when there's nothing to go back to, e.g. a direct deep link.
 23: function leaveSession(router: ReturnType<typeof useRouter>) {
 24:   if (typeof window !== "undefined" && window.history.length > 1) {
 25:     router.back();
 26:   } else {
 27:     router.push("/");
 28:   }
 29: }
 30: 
 31: function useWakeLock(active: boolean) {
 32:   useEffect(() => {
 33:     if (!active || !("wakeLock" in navigator)) return;
 34:     let lock: WakeLockSentinel | null = null;
 35:     let cancelled = false;
 36:     const acquire = async () => {
 37:       try {
 38:         lock = await navigator.wakeLock.request("screen");
 39:         if (cancelled) void lock.release();
 40:       } catch {
 41:         // low battery or unsupported — not critical
 42:       }
 43:     };
 44:     void acquire();
 45:     const onVisible = () => {
 46:       if (document.visibilityState === "visible") void acquire();
 47:     };
 48:     document.addEventListener("visibilitychange", onVisible);
 49:     return () => {
 50:       cancelled = true;
 51:       document.removeEventListener("visibilitychange", onVisible);
 52:       void lock?.release();
 53:     };
 54:   }, [active]);
 55: }
 56: 
 57: function SessionPageInner() {
 58:   const teaId = useSearchParams().get("tea") ?? "";
 59:   const router = useRouter();
 60: 
 61:   const custom = useProfiles((s) => s.custom);
 62:   const profilesHydrated = useProfiles((s) => s.hydrated);
 63:   const settings = useSettings();
 64:   const session = useSession();
 65:   const { t, lang } = useT();
 66:   const tea = findTea(teaId, custom);
 67: 
 68:   const [now, setNow] = useState(() => Date.now());
 69:   const firedRef = useRef(false);
 70:   // A direct override for leaf grams, independent of the vessel-derived
 71:   // default. Resets whenever the tea changes so a new session starts fresh.
 72:   const [gramsOverride, setGramsOverride] = useState<number | null>(null);
 73:   useEffect(() => {
 74:     setGramsOverride(null);
 75:   }, [tea?.id]);
 76: 
 77:   // Start (or resume) a session for this tea.
 78:   useEffect(() => {
 79:     if (!tea || !profilesHydrated) return;
 80:     if (useSession.getState().tea?.id !== tea.id) {
 81:       useSession.getState().begin(tea, useSettings.getState().strength);
 82:     }
 83:   }, [tea, profilesHydrated]);
 84: 
 85:   const { timer, steepIndex, steepDurations, steepsCompleted, finished } =
 86:     session;
 87:   const running = timer.status === "running";
 88: 
 89:   useWakeLock(running && settings.keepScreenOn);
 90: 
 91:   const fireAlarm = useCallback(() => {
 92:     if (firedRef.current) return;
 93:     firedRef.current = true;
 94:     const s = useSettings.getState();
 95:     if (s.sound) playChime();
 96:     if (s.notifications && session.tea) {
 97:       const strings = STRINGS[s.language];
 98:       const names = teaNames(session.tea, s.language);
 99:       notifySteepDone(
100:         strings.steepDoneTitle(names.primary, steepIndex + 1),
101:         strings.steepDoneBody,
102:       );
103:     }
104:     if (s.vibration) vibrate();
105:     useSession.getState().completeSteep();
106:     // Allow the next steep's alarm.
107:     setTimeout(() => {
108:       firedRef.current = false;
109:     }, 500);
110:   }, [session.tea, steepIndex]);
111: 
112:   // Display tick + expiry check. A plain interval, not requestAnimationFrame —
113:   // mobile Safari aggressively throttles rAF during idle foreground time (no
114:   // touch/scroll), only "waking" it on interaction, which froze the countdown
115:   // ring and liquid until something else forced a re-render. setInterval
116:   // doesn't get throttled the same way. Timestamp math (not tick count) keeps
117:   // the actual time accurate regardless of tick cadence.
118:   useEffect(() => {
119:     if (!running) return;
120:     const tick = () => {
121:       setNow(Date.now());
122:       if (isExpired(useSession.getState().timer)) fireAlarm();
123:     };
124:     tick();
125:     const interval = setInterval(tick, 200);
126:     // Backup in case the interval itself gets throttled: fire right at the
127:     // deadline regardless.
128:     const left = remainingMs(timer);
129:     const backup = setTimeout(() => {
130:       if (isExpired(useSession.getState().timer)) fireAlarm();
131:     }, left + 50);
132:     return () => {
133:       clearInterval(interval);
134:       clearTimeout(backup);
135:     };
136:   }, [running, timer, fireAlarm]);
137: 
138:   if (!tea) {
139:     if (!profilesHydrated) return null;
140:     return (
141:       <div className="pt-20 text-center">
142:         <p className="text-muted">{t.teaNotFound}</p>
143:         <Link href="/" className="mt-3 inline-block font-semibold underline">
144:           {t.backToTeas}
145:         </Link>
146:       </div>
147:     );
148:   }
149:   if (!session.tea || session.tea.id !== tea.id) return null;
150: 
151:   const durationMs = timer.durationMs || 1;
152:   const leftMs = remainingMs(timer, now);
153:   const elapsed = finished ? 1 : 1 - leftMs / durationMs;
154:   const doneWaiting = timer.status === "done" && !finished;
155:   const color = tea.liquorColor;
156:   const totalSteeps = steepDurations.length;
157:   const grams =
158:     gramsOverride ?? leafGrams(tea.ratioGramsPer100ml, settings.vesselMl);
159:   // Grams and vessel are fixed for the log the moment the first steep
160:   // starts, so lock both steppers once brewing is underway to avoid a
161:   // display/log mismatch.
162:   const vesselLocked = steepIndex > 0 || timer.status !== "idle";
163:   const adjustVessel = (deltaMl: number) =>
164:     useSettings
165:       .getState()
166:       .update({ vesselMl: Math.min(500, Math.max(20, settings.vesselMl + deltaMl)) });
167:   const adjustGrams = (delta: number) =>
168:     setGramsOverride(Math.min(30, Math.max(0.5, Math.round((grams + delta) * 10) / 10)));
169: 
170:   return (
171:     <div className="flex min-h-[calc(100dvh-6rem)] flex-col">
172:       <header className="mb-2 flex items-start justify-between gap-3">
173:         <button
