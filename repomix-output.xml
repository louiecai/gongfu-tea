 3: import { useEffect } from "react";
 4: import { useSettings } from "@/store/settings";
 5: import { useProfiles } from "@/store/profiles";
 6: import { useLog } from "@/store/log";
 7: import { useStash } from "@/store/stash";
 8: import { useActiveSessions } from "@/store/activeSessions";
 9: 
10: /**
11:  * Client bootstrap: hydrate stores from localStorage, keep the theme class
12:  * in sync, register the service worker.
13:  */
14: export function Boot() {
15:   const theme = useSettings((s) => s.theme);
16:   const language = useSettings((s) => s.language);
17:   const hydrated = useSettings((s) => s.hydrated);
18: 
19:   useEffect(() => {
20:     if (hydrated) {
21:       document.documentElement.lang = language === "zh" ? "zh-CN" : "en";
22:     }
23:   }, [language, hydrated]);
24: 
25:   useEffect(() => {
26:     useSettings.getState().hydrate();
27:     useProfiles.getState().hydrate();
28:     useLog.getState().hydrate();
29:     useStash.getState().hydrate();
30:     useActiveSessions.getState().hydrate();
31:   }, []);
32: 
33:   useEffect(() => {
34:     if (!hydrated) return;
35:     const root = document.documentElement;
36:     const media = window.matchMedia("(prefers-color-scheme: dark)");
37:     const apply = () => {
38:       const dark =
39:         theme === "dark" || (theme === "system" && media.matches);
40:       root.classList.toggle("dark", dark);
41:     };
42:     apply();
43:     media.addEventListener("change", apply);
44:     return () => media.removeEventListener("change", apply);
45:   }, [theme, hydrated]);
46: 
47:   useEffect(() => {
48:     if ("serviceWorker" in navigator && process.env.NODE_ENV === "production") {
49:       void navigator.serviceWorker.register("/sw.js");
50:     }
51:   }, []);
52: 
53:   return null;
54: }
</file>

