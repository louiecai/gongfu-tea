<file path="src/store/stash.ts">
 1: import { create } from "zustand";
 2: import type { StashItem } from "@/lib/types";
 3: import { stashRepo } from "@/lib/repo";
 4: 
 5: interface StashStore {
 6:   items: StashItem[];
 7:   hydrated: boolean;
 8:   hydrate: () => void;
 9:   save: (item: StashItem) => void;
10:   remove: (teaId: string) => void;
11:   /**
12:    * Called when a brew session starts with the leaf grams the vessel needs
13:    * (from the tea's ratio); returns grams actually used (0 if not stashed,
14:    * clamped to what's left).
15:    */
16:   consumeForSession: (teaId: string, grams: number) => number;
17: }
18: 
19: export const useStash = create<StashStore>((set, get) => ({
20:   items: [],
21:   hydrated: false,
22: 
23:   hydrate: () => {
24:     set({ items: stashRepo.load() ?? [], hydrated: true });
25:   },
26: 
27:   save: (item) => {
28:     const items = get().items.filter((i) => i.teaId !== item.teaId);
29:     items.push(item);
30:     set({ items });
31:     stashRepo.save(items);
32:   },
33: 
34:   remove: (teaId) => {
35:     const items = get().items.filter((i) => i.teaId !== teaId);
36:     set({ items });
37:     stashRepo.save(items);
38:   },
39: 
40:   consumeForSession: (teaId, grams) => {
41:     const item = get().items.find((i) => i.teaId === teaId);
42:     if (!item) return 0;
43:     const used = Math.min(item.gramsRemaining, grams);
44:     const items = get().items.map((i) =>
45:       i.teaId === teaId
46:         ? { ...i, gramsRemaining: Math.max(0, i.gramsRemaining - used) }
47:         : i,
48:     );
49:     set({ items });
50:     stashRepo.save(items);
51:     return used;
52:   },
53: }));
</file>

