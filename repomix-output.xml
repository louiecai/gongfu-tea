 1: import type {
 2:   ActiveSession,
 3:   BrewSession,
 4:   Settings,
 5:   StashItem,
 6:   TeaProfile,
 7: } from "./types";
 8: 
 9: /**
10:  * Persistence boundary. Everything below the stores goes through a Repo so a
11:  * backend implementation can replace LocalStorageRepo without touching UI.
12:  */
13: export interface Repo<T> {
14:   load(): T | null;
15:   save(value: T): void;
16: }
17: 
18: class LocalStorageRepo<T> implements Repo<T> {
19:   constructor(private key: string) {}
20: 
21:   load(): T | null {
22:     if (typeof window === "undefined") return null;
23:     try {
24:       const raw = window.localStorage.getItem(this.key);
25:       return raw ? (JSON.parse(raw) as T) : null;
26:     } catch {
27:       return null;
28:     }
29:   }
30: 
31:   save(value: T): void {
32:     if (typeof window === "undefined") return;
33:     try {
34:       window.localStorage.setItem(this.key, JSON.stringify(value));
35:     } catch {
36:       // storage full or blocked — fail quietly, app still works in-memory
37:     }
38:   }
39: }
40: 
41: const PREFIX = "gongfu.";
42: 
43: export const profilesRepo: Repo<TeaProfile[]> = new LocalStorageRepo(
44:   `${PREFIX}profiles`,
45: );
46: export const logRepo: Repo<BrewSession[]> = new LocalStorageRepo(
47:   `${PREFIX}log`,
48: );
49: export const stashRepo: Repo<StashItem[]> = new LocalStorageRepo(
50:   `${PREFIX}stash`,
51: );
52: export const settingsRepo: Repo<Settings> = new LocalStorageRepo(
53:   `${PREFIX}settings`,
54: );
55: /** One entry per unfinished brew — lets several sessions stay resumable at once. */
56: export const activeSessionsRepo: Repo<ActiveSession[]> = new LocalStorageRepo(
57:   `${PREFIX}activeSessions`,
58: );
