<file path="src/components/ScrollRestoration.tsx">
 1: "use client";
 2: 
 3: import { useEffect, useRef } from "react";
 4: import { usePathname } from "next/navigation";
 5: 
 6: /**
 7:  * Each bottom-nav tab keeps its own scroll position, like a native app's tab
 8:  * bar, instead of resetting to the top every time you switch back to it.
 9:  * Paired with `scroll={false}` on the Nav links, which otherwise fight this
10:  * by asking Next to scroll to top on every tab switch.
11:  */
12: const positions = new Map<string, number>();
13: 
14: export function ScrollRestoration() {
15:   const pathname = usePathname();
16:   const current = useRef(pathname);
17: 
18:   useEffect(() => {
19:     window.scrollTo(0, positions.get(pathname) ?? 0);
20:     current.current = pathname;
21:   }, [pathname]);
22: 
23:   useEffect(() => {
24:     const onScroll = () => positions.set(current.current, window.scrollY);
25:     window.addEventListener("scroll", onScroll, { passive: true });
26:     return () => window.removeEventListener("scroll", onScroll);
27:   }, []);
28: 
29:   return null;
30: }
</file>

