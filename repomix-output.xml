203:             ))}
204:           </ul>
205:         </section>
206:       ))}
207: 
208:       {groups.byCategory.length === 0 && groups.customTeas.length === 0 && (
209:         <p className="mt-16 text-center text-sm text-muted">
210:           {t.noMatch(query)}
211:         </p>
212:       )}
213:     </div>
214:   );
215: }
