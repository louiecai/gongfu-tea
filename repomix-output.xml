267:               </span>
268:               <span className="mt-1 text-xs text-muted">
269:                 {doneWaiting
270:                   ? t.pouredReady
271:                   : running
272:                     ? t.steeping
273:                     : timer.status === "paused"
274:                       ? t.paused
275:                       : session.justFinishedSteep
276:                         ? t.pourThenStart
277:                         : t.tapStart}
278:               </span>
279:             </TimerCup>
