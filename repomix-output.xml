  1: "use client";
  2: 
  3: /**
  4:  * The signature element: a porcelain cup seen from above. The liquor rises
  5:  * with a drifting wave as the steep progresses, while a hairline ring
  6:  * counts the time down. Everything else on the screen stays quiet.
  7:  */
  8: 
  9: const RING_R = 104;
 10: const CUP_R = 88;
 11: const LIQUID_R = 84;
 12: const CIRC = 2 * Math.PI * RING_R;
 13: 
 14: // One wave segment is 220 wide; the path repeats it so a 220px translate
 15: // loops seamlessly.
 16: const WAVE_D =
 17:   "M0,12 Q27.5,2 55,12 T110,12 T165,12 T220,12 T275,12 T330,12 T385,12 T440,12 V240 H0 Z";
 18: 
 19: export function TimerCup({
 20:   progress,
 21:   color,
 22:   ripple,
 23:   idle,
 24:   children,
 25: }: {
 26:   /** 0 → empty cup, 1 → full (elapsed fraction of the steep). */
 27:   progress: number;
 28:   color: string;
 29:   /** Pulse rings outward (steep just finished). */
 30:   ripple?: boolean;
 31:   /** Waiting for the first tap — gives the ring a gentle "come start me" pulse. */
 32:   idle?: boolean;
 33:   children?: React.ReactNode;
 34: }) {
 35:   const p = Math.min(1, Math.max(0, progress));
 36:   // Liquid surface: from just above the cup bottom to fully at the rim. The
 37:   // wave path (see WAVE_D) dips as low as +12 from its own reference point,
 38:   // so the travel distance overshoots the rim by that much — otherwise the
 39:   // wave's troughs leave a visible gap at 100% even though its crests reach.
 40:   const surfaceY = 110 + LIQUID_R - 8 - p * (2 * LIQUID_R + 8);
 41:   const ringOffset = CIRC * p;
 42: 
 43:   return (
 44:     <div className="relative mx-auto aspect-square w-full max-w-[320px]">
 45:       <svg viewBox="0 0 220 220" className="h-full w-full">
 46:         <defs>
 47:           <clipPath id="cup-clip">
 48:             <circle cx="110" cy="110" r={LIQUID_R} />
 49:           </clipPath>
 50:         </defs>
 51: 
 52:         {/* countdown ring */}
 53:         <circle
 54:           cx="110"
 55:           cy="110"
 56:           r={RING_R}
 57:           fill="none"
 58:           stroke="var(--line)"
 59:           strokeWidth="2"
 60:         />
 61:         <circle
 62:           cx="110"
 63:           cy="110"
 64:           r={RING_R}
 65:           fill="none"
 66:           stroke={color}
 67:           strokeWidth="3"
 68:           strokeLinecap="round"
 69:           strokeDasharray={CIRC}
 70:           strokeDashoffset={ringOffset}
 71:           transform="rotate(-90 110 110)"
 72:           className={idle ? "ring-idle-pulse" : undefined}
 73:           style={{ transition: "stroke-dashoffset 0.3s linear" }}
 74:         />
 75: 
 76:         {/* porcelain */}
 77:         <circle
 78:           cx="110"
 79:           cy="110"
 80:           r={CUP_R}
 81:           fill="var(--surface)"
 82:           stroke="var(--line)"
 83:           strokeWidth="1.5"
 84:         />
 85: 
 86:         {/* liquor */}
 87:         <g clipPath="url(#cup-clip)">
 88:           <g style={{ transform: `translateY(${surfaceY}px)`, transition: "transform 0.4s ease" }}>
 89:             <g className="wave-drift-slow">
 90:               <path d={WAVE_D} fill={color} opacity="0.45" />
 91:             </g>
 92:             <g className="wave-drift">
 93:               <path d={WAVE_D} fill={color} opacity="0.85" transform="translate(0,4)" />
 94:             </g>
 95:           </g>
 96:         </g>
 97: 
 98:         {/* rim highlight */}
 99:         <circle
100:           cx="110"
101:           cy="110"
102:           r={LIQUID_R}
103:           fill="none"
104:           stroke="var(--bg)"
105:           strokeWidth="3"
106:           opacity="0.6"
107:         />
108:       </svg>
109: 
110:       {ripple && (
111:         <>
112:           <span
113:             aria-hidden
114:             className="steep-glow pointer-events-none absolute inset-[-10%] rounded-full"
115:             style={{ background: `radial-gradient(circle, ${color}4d, transparent 70%)` }}
116:           />
117:           <span
118:             aria-hidden
119:             className="steep-ripple absolute inset-[6%] rounded-full border-2"
120:             style={{ borderColor: color }}
121:           />
122:           <span
123:             aria-hidden
124:             className="steep-ripple absolute inset-[6%] rounded-full border-2"
125:             style={{ borderColor: color, animationDelay: "0.8s" }}
126:           />
127:         </>
128:       )}
129: 
130:       <div className="absolute inset-0 flex flex-col items-center justify-center">
131:         <div className="flex flex-col items-center rounded-2xl bg-surface/70 px-5 py-2.5 text-center backdrop-blur-sm">
132:           {children}
133:         </div>
134:       </div>
135:     </div>
136:   );
137: }
