10: import { useSettings } from "@/store/settings";
11: 
12: export function TeaCard({ tea, index }: { tea: TeaProfile; index: number }) {
13:   const { t, lang } = useT();
14:   const names = teaNames(tea, lang);
15:   const isFavorite = useSettings((s) => s.favorites.includes(tea.id));
16: 
17:   const toggleFavorite = (e: React.MouseEvent) => {
18:     e.preventDefault();
19:     const { favorites } = useSettings.getState();
20:     useSettings.getState().update({
21:       favorites: isFavorite
22:         ? favorites.filter((id) => id !== tea.id)
23:         : [...favorites, tea.id],
24:     });
25:   };
26: 
27:   return (
28:     <motion.li
29:       initial={{ opacity: 0, y: 10 }}
30:       animate={{ opacity: 1, y: 0 }}
31:       transition={{ delay: Math.min(index * 0.03, 0.4), duration: 0.35 }}
32:       className="relative"
33:     >
34:       <span className="absolute right-2.5 top-2.5 z-10 flex items-center gap-2.5">
35:         <Link
36:           href={`/tea?id=${tea.id}`}
37:           aria-label={t.viewDetails}
38:           className="text-sm leading-none text-muted opacity-70 transition-transform hover:scale-125 hover:text-ink"
39:         >
40:           ⓘ
41:         </Link>
42:         <button
43:           type="button"
44:           onClick={toggleFavorite}
45:           aria-pressed={isFavorite}
46:           aria-label={isFavorite ? t.unfavorite : t.favorite}
47:           className={`text-base leading-none transition-transform hover:scale-125 active:scale-95 ${
48:             isFavorite ? "" : "opacity-30 grayscale"
49:           }`}
50:         >
51:           ★
52:         </button>
53:       </span>
54:       <Link
55:         href={`/session?tea=${tea.id}`}
56:         className="group flex items-center gap-3.5 rounded-2xl border border-line bg-surface p-3.5 transition-all hover:-translate-y-0.5 hover:shadow-md hover:shadow-[var(--lift)] active:scale-[.98]"
57:       >
58:         <span
59:           className="flex h-11 w-11 shrink-0 items-center justify-center rounded-full"
60:           style={{
61:             color: tea.liquorColor,
62:             background: `color-mix(in srgb, ${tea.liquorColor} 16%, transparent)`,
63:           }}
64:         >
65:           <TeaIcon icon={tea.icon} className="h-6 w-6" />
66:         </span>
67:         <span className="min-w-0 flex-1">
68:           <span className="flex items-baseline gap-2">
69:             <span className="font-display truncate text-[15px] font-medium">
70:               {names.primary}
71:             </span>
72:             {names.secondary && (
73:               <span className="shrink-0 text-xs text-muted">
74:                 {names.secondary}
75:               </span>
76:             )}
77:           </span>
78:           <span className="mt-0.5 block text-xs text-muted">
79:             {t.cardMeta(
80:               tea.steepsSec.length,
81:               formatSeconds(tea.steepsSec[0]),
82:               tea.tempC,
83:             )}
84:           </span>
85:         </span>
86:         {/* Tasting-cup dot: a sip of the liquor color. */}
87:         <span
88:           aria-hidden
89:           className="h-3 w-3 shrink-0 rounded-full ring-2 ring-inset ring-black/5 transition-transform group-hover:scale-125 dark:ring-white/10"
90:           style={{ background: tea.liquorColor }}
91:         />
92:       </Link>
93:     </motion.li>
94:   );
95: }
